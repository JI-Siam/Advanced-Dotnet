@model Jasim_Plaza_Tenant_Portal.Models.LoginViewModel

<div class="mx-auto max-w-xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Login</h1>
        <p class="mt-1 text-sm text-slate-600">Sign in to access shop and rent modules.</p>
        @if (TempData["msg"] != null)
        {
            <div class="mt-4 rounded-xl border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["msg"]
            </div>
        }

        <div class="mt-4 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-900">
            <p class="font-semibold">Demo Credentials</p>
            <p class="mt-1">Admin: admin@jasimplaza.local / admin123</p>
            <p>Owner: owner@jasimplaza.local / owner123</p>
            <p>Owner 2: owner2@jasimplaza.local / owner123</p>
        </div>

        <form asp-action="Login" method="post" class="mt-5 space-y-4">
            <input type="hidden" asp-for="ReturnUrl" />

            <div>
                <label asp-for="Email" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Email"
                       class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
                <span asp-validation-for="Email" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Password" type="password"
                       class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
                <span asp-validation-for="Password" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <button type="submit"
                    class="w-full rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">Login</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
