@model List<Jasim_Plaza_Tenant_Portal.EF.Tables.User>

@{
    var currentUser = ViewBag.CurrentUser as Jasim_Plaza_Tenant_Portal.EF.Tables.User;
}

<h1>User Management</h1>
<p class="mt-1 text-sm text-slate-600">User list for reference.</p>
@if (TempData["msg"] != null)
{
    <div class="mt-3 rounded-xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@TempData["msg"]
    </div>
}

<div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                    <th class="px-4 py-3">Id</th>
                    <th class="px-4 py-3">Name</th>
                    <th class="px-4 py-3">Email</th>
                    <th class="px-4 py-3">Role</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-700">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3">@user.Id</td>
                        <td class="px-4 py-3 font-medium">@user.Name</td>
                        <td class="px-4 py-3">@user.Email</td>
                        <td class="px-4 py-3">
                            <span
                            class="rounded-full px-2.5 py-1 text-xs font-semibold @(user.Role == "Admin" ? "bg-slate-900 text-white" : "bg-cyan-100 text-cyan-800")">@user.Role</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-action="Profile"
       class="mt-4 inline-flex rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">Update
    My Profile</a>