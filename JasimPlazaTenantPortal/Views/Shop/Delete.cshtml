@model Jasim_Plaza_Tenant_Portal.EF.Tables.Shop

<div class="mx-auto max-w-2xl">
    <div class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Delete Shop</h1>
        <p class="mt-1 text-sm text-slate-600">This action cannot be undone.</p>

        <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <strong>Confirm delete:</strong> @Model.ShopName (@Model.Location)
        </div>

        <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm">
            <p><span class="font-semibold">Owner:</span> @Model.Owner.Name</p>
            <p class="mt-1"><span class="font-semibold">Monthly Rent:</span> @Model.MonthlyRent.ToString("N2") BDT</p>
        </div>

        <form asp-action="Delete" method="post" class="mt-5">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="flex flex-wrap gap-2">
                <button type="submit"
                        class="rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700">Delete
                    Shop</button>
                    <a asp-action="Index"
                       class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Cancel</a>
                </div>
            </form>
        </div>
    </div>
