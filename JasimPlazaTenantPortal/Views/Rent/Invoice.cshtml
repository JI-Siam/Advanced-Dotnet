@model Jasim_Plaza_Tenant_Portal.EF.Tables.RentRecord
@{
    Layout = "_Layout";
    var monthNames = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    var adminInvoiceId = $"INV-{Model.Id}-{Model.ShopId}-{Model.Month:D2}";
    var ownerInvoiceId = $"INV-{Model.Id}-{Model.Month:D2}";
    var isAdmin = Context.Session.GetString("CurrentUserRole") == "Admin";
}

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .invoice-card {
            box-shadow: none !important;
            border-color: #d1d5db !important;
        }
    }
</style>

<div class="no-print mb-4 flex flex-col justify-between gap-3 sm:flex-row sm:items-center">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Invoice</h1>
    <button class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
            onclick="window.print()">Print / Save PDF</button>
</div>

@if (TempData["msg"] != null)
{
    <div class="no-print mb-4 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-900">@TempData["msg"]
    </div>
}

<div class="invoice-card rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
    <div class="mb-5 flex items-start justify-between gap-4 border-b border-slate-200 pb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900">Jasim Plaza Tenant Portal</h2>
            <p class="mt-1 text-sm text-slate-500">Official rent invoice</p>
        </div>
        <div class="text-right text-sm text-slate-600">
            <p class="font-semibold text-slate-900">Invoice #@(isAdmin ? adminInvoiceId : ownerInvoiceId)</p>
            <p>Generated on @DateTime.Now.ToString("yyyy-MM-dd")</p>
        </div>
    </div>

    <div class="grid gap-3 text-sm text-slate-700 sm:grid-cols-2">
        <p><span class="font-semibold">Shop:</span> @Model.Shop.ShopName</p>
        <p><span class="font-semibold">Owner:</span> @Model.Shop.Owner.Name (@Model.Shop.Owner.Email)</p>
        <p><span class="font-semibold">Location:</span> @Model.Shop.Location</p>
        <p><span class="font-semibold">Billing Period:</span> @Model.Month @monthNames[Model.Month - 1] / @Model.Year
        </p>
        <p><span class="font-semibold">Amount:</span> @Model.Amount.ToString("N2") BDT</p>
        <p><span class="font-semibold">Status:</span> @Model.Status</p>
        <p class="sm:col-span-2"><span class="font-semibold">Payment Date:</span>
            @(Model.PaymentDate?.ToString("yyyy-MM-dd") ?? "Not paid yet")</p>
        </div>

        @if (Model.Status == "Paid")
        {
            <p class="mt-5 rounded-xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700">
                Payment Completed</p>
            }
    else if (Model.Status == "Due")
            {
                <p class="mt-5 rounded-xl border border-rose-100 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">Payment
                    Due</p>
                }
    else
                {
                    <p class="mt-5 rounded-xl border border-amber-100 bg-amber-50 px-4 py-3 text-sm font-semibold text-amber-700">
                        Payment Pending</p>
                    }
                </div>

                <div class="no-print mt-4">
                    @if (isAdmin)
                    {
                        <a asp-action="Details" asp-route-id="@Model.Id"
                               class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Back
                            to Details</a>
                        }
                    else
                        {
                            @if (!string.Equals(Model.Status, "Paid", StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="PayWithBkash" method="post" class="mb-3 inline-block">
                                    <input type="hidden" name="invoiceId" value="@ownerInvoiceId" />
                                    <button type="submit"
                                            class="rounded-xl bg-pink-600 px-4 py-2 text-sm font-semibold text-white hover:bg-pink-700">Pay with
                                        bKash</button>
                                    </form>
                                }
                                <a asp-action="DetailsByCode" asp-route-invoiceId="@ownerInvoiceId"
                                       class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Back
                                    to Details</a>
                                }
                            </div>
