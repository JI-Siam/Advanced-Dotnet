@model List<Jasim_Plaza_Tenant_Portal.EF.Tables.Shop>

@{
    var monthNames = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
}

<div class="mx-auto max-w-2xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Create Rent Record</h1>
        <p class="mt-1 text-sm text-slate-600">Admin only: add or correct monthly rent records for a shop.</p>
        @if (TempData["msg"] != null)
        {
            <div class="mt-4 rounded-xl border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["msg"]
            </div>
        }

        <form asp-action="Create" method="post" class="mt-5 space-y-4">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Shop</label>
                <select name="ShopId" class="w-full rounded-xl border border-slate-300 px-3 py-2" required>
                    <option value="" disabled selected>Select Shop</option>
                    @foreach (var shop in Model)
                    {
                        <option value="@shop.Id">@shop.ShopName - @shop.Owner.Name</option>
                    }
                </select>
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Month</label>
                <select name="Month" class="w-full rounded-xl border border-slate-300 px-3 py-2" required>
                    <option value="" disabled selected>Select month</option>
                    @for (var i = 1; i <= 12; i++)
                    {
                        <option value="@i">@i @monthNames[i - 1]</option>
                    }
                </select>
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Year</label>
                <input type="number" name="Year" min="2000" max="2100" placeholder="Year"
                       class="w-full rounded-xl border border-slate-300 px-3 py-2" required>
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Amount</label>
                <input type="number" name="Amount" min="1" step="0.01" placeholder="Amount"
                       class="w-full rounded-xl border border-slate-300 px-3 py-2" required>
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Status</label>
                <select name="Status" class="w-full rounded-xl border border-slate-300 px-3 py-2" required>
                    <option value="" disabled selected>Select payment status</option>
                    <option value="Paid">Paid</option>
                    <option value="Pending">Pending</option>
                    <option value="Due">Due</option>
                </select>
            </div>

            <div class="flex flex-wrap gap-2 pt-1">
                <button type="submit"
                        class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">Save
                    Record</button>
                    <a asp-action="Index"
                       class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Cancel</a>
                </div>
            </form>
        </div>
    </div>