@{
    ViewData["Title"] = "Home Page";
    var isAdmin = ViewBag.IsAdmin is true;
    var currentUser = ViewBag.CurrentUser as Jasim_Plaza_Tenant_Portal.EF.Tables.User;
}

<div class="text-center mb-4">
    <div
        class="mx-auto mb-4 inline-flex rounded-full border border-blue-100 bg-blue-50 px-4 py-1 text-xs font-semibold uppercase tracking-wider text-blue-700">
        Tenant Operations</div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Jasim Plaza Tenant Portal</h1>
        <p class="mx-auto mt-2 max-w-2xl text-slate-600">Role-based management for shops, users, and monthly rent tracking
            with automated monthly records.</p>
            <p class="mt-3 text-sm text-slate-500"><span class="font-semibold text-slate-700">Current User:</span>
                @currentUser?.Name (@currentUser?.Role)</p>
            </div>

            @if (isAdmin)
            {
                <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-slate-500">Total Shops</p>
                        <p class="mt-2 text-2xl font-bold text-slate-900">@ViewBag.TotalShops</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-slate-500">Shop Owners</p>
                        <p class="mt-2 text-2xl font-bold text-slate-900">@ViewBag.TotalOwners</p>
                    </div>
                    <div class="rounded-2xl border border-red-100 bg-red-50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-red-500">Due</p>
                        <p class="mt-2 text-2xl font-bold text-red-600">@ViewBag.DueRecords</p>
                    </div>
                    <div class="rounded-2xl border border-amber-100 bg-amber-50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-amber-600">Pending</p>
                        <p class="mt-2 text-2xl font-bold text-amber-600">@ViewBag.PendingRecords</p>
                    </div>
                    <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-emerald-600">Paid</p>
                        <p class="mt-2 text-2xl font-bold text-emerald-600">@ViewBag.PaidRecords</p>
                    </div>
                    <div class="rounded-2xl border border-rose-100 bg-rose-50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase text-rose-600">Shops With Due</p>
                        <p class="mt-2 text-2xl font-bold text-rose-600">@ViewBag.ShopsWithDue</p>
                    </div>
                </div>
            }

            <div class="mb-6 rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm text-blue-900">
                <p class="font-semibold">Demo Credentials</p>
                <p class="mt-1">Admin: admin@jasimplaza.local / admin123</p>
                <p>Owner: owner@jasimplaza.local / owner123</p>
                <p>Owner 2: owner2@jasimplaza.local / owner123</p>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-slate-900">User Management</h2>
                    <p class="mt-2 text-sm text-slate-600">View users and update your profile.</p>
                    <a asp-controller="User" asp-action="Index"
                           class="mt-4 inline-flex rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open
                        Users</a>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <h2 class="text-lg font-semibold text-slate-900">Shop Management</h2>
                        <p class="mt-2 text-sm text-slate-600">Create, edit, and maintain shop-owner assignments.</p>
                        <a asp-controller="Shop" asp-action="Index"
                               class="mt-4 inline-flex rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open
                            Shops</a>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <h2 class="text-lg font-semibold text-slate-900">Rent Management</h2>
                            <p class="mt-2 text-sm text-slate-600">Track monthly records, filter quickly, and print invoices.</p>
                            <a asp-controller="Rent" asp-action="Index"
                                   class="mt-4 inline-flex rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open
                                Rent</a>
                            </div>
                        </div>