@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">@ViewData["Title"]</h1>
    <p class="mt-3 text-sm leading-6 text-slate-700">
        This tenant portal stores essential account, shop, and rent data to manage billing and operations.
        Access is role-restricted, and user sessions are required for protected actions.
    </p>
    <p class="mt-3 text-sm leading-6 text-slate-700">
        For demo mode, seeded credentials are available to simulate Admin and Owner workflows. In production,
        use secure authentication, hashed passwords, and a hardened deployment configuration.
    </p>
</div>
