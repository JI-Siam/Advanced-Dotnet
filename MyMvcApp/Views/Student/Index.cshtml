<h1>Student Informations</h1>
<table class="table table-bordered">
    <thead>
        <tr>
            <td>Id</td>
            <td>Name</td>
            <td>Cgpa</td>
        </tr>
    </thead>
    <tbody>
        @foreach (dynamic item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Cgpa</td>
                <td>
                    <a href="./details/@item.Id" class="btn btn-info">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>