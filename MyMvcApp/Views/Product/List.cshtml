<h1>Product List</h1>
<table class="table table-bordered">
    <thead>
        <tr>
            <td>Id</td>
            <td>Product Name</td>
            <td>Quantity</td>
            <td>Price</td>
            <td>Options</td>
        </tr>
    </thead>

    <tbody>
        @foreach (dynamic item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price</td>
                <td><a href="./details/@item.Id" class="btn btn-info">View</a></td>
            </tr>
        }
    </tbody>
</table>