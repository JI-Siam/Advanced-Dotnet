<h1>Category List</h1>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name </th>
    </tr>

    <tr>
        @{
            foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Id</td>
                    <td>@cat.Name</td>
                </tr>
            }
        }
    </tr>
</table>