<h1>Add Employee</h1>

<form action="" method="post">
    Employee Name: <input type="text" name="EmployeeName" class="form-control" placeholder="Enter Employee Name">
    Employee Id: <input type="text" name="EmployeeId" class="form-control" placeholder="Enter EmployeeIde">
    Performance Score: <input type="number" step="0.01" name="PerformanceScore" class="form-control"
                              placeholder="Enter Employee PerformanceScore">
    Lowest Project Rating: <input type="number" step="0.01" name="LowestProjectRating" class="form-control"
                                  placeholder="Enter Employee LowestProjectRating ">
    Total Projects Completed: <input type="number" step="0.01" name="TotalProjectsCompleted" class="form-control"
                                     placeholder="Enter Employee TotalProjectsCompleted">

    <input class="btn btn-success" type="submit" value="Create">

</form>