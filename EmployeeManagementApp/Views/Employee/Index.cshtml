<h1>Employee List</h1> <a asp-controller="Employee" asp-action="Create" class="btn btn-outline-secondary">Add
Employee</a>

<h5 class="text-danger text-center fw-bolder">@TempData["deleteMsg"]</h5>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Employee Name</th>
            <th>Employee ID</th>
            <th>Performance Score</th>
            <th>Lowest Project Rating</th>
            <th>Total Projects Completed</th>
            <th>Options</th>
        </tr>
    </thead>

    <tbody>
        @{
            foreach (var employee in Model)
            {
                <tr>
                    <td>@employee.EmployeeName</td>
                    <td>@employee.EmployeeId</td>
                    <td>@employee.PerformanceScore</td>
                    <td>@employee.LowestProjectRating</td>
                    <td>@employee.TotalProjectsCompleted</td>
                    <td><a href="./Employee/Details/@employee.EmployeeId" class="btn btn-outline-info">Details
                    </a>
                    <a href="./Employee/Delete/@employee.EmployeeId" class="btn btn-outline-info">Remove
                    </a>
                    <a href="./Employee/Edit/@employee.EmployeeId" class="btn btn-outline-info">Edit
                    </a>
                </td>
            </tr>
        }
    }
</tbody>
</table>

<h1>Filtered Employee List</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Employee Name</th>
            <th>Employee ID</th>
            <th>Employee Details</th>

        </tr>
    </thead>

    <tbody>
        @{
            foreach (var employee in Model)
            {
                if (employee.PerformanceScore >= 4.7m)
                {

                    <tr>
                        <td>@employee.EmployeeName</td>
                        <td>@employee.EmployeeId</td>
                        <td> PS- @employee.PerformanceScore , LPR-@employee.LowestProjectRating ,
                            PC-@employee.TotalProjectsCompleted </td>
                        </tr>
                    }
               
                }
            }
        </tbody>
    </table>