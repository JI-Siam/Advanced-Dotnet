@model EmployeeManagementApp.EF.Tables.Employee

<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h1 class="h4 mb-0">Employee Details</h1>
                <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 bg-light-subtle">
                            <div class="text-muted small">Employee Name</div>
                            <div class="fw-semibold">@Model.EmployeeName</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 bg-light-subtle">
                            <div class="text-muted small">Employee ID</div>
                            <div class="fw-semibold">@Model.EmployeeId</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3">
                            <div class="text-muted small mb-1">Performance Score</div>
                            <span
                            class="badge fs-6 @(Model.PerformanceScore >= 4.5m ? "bg-success" : "bg-danger")">@Model.PerformanceScore</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3">
                            <div class="text-muted small mb-1">Lowest Project Rating</div>
                            <span
                            class="badge fs-6 @(Model.LowestProjectRating > 3.7m ? "bg-success" : "bg-danger")">@Model.LowestProjectRating</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3">
                            <div class="text-muted small mb-1">Total Projects Completed</div>
                            <span
                            class="badge fs-6 @(Model.TotalProjectsCompleted >= 6 ? "bg-success" : "bg-danger")">@Model.TotalProjectsCompleted</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    @{
                        if (Model.PerformanceScore >= 4.5m && Model.LowestProjectRating > 3.7m &&
                    Model.TotalProjectsCompleted >= 6)
                        {
                            <div class="alert alert-success fw-semibold mb-0" role="alert">Excellent Employee</div>
                        }
                        else
                        {
                            <div class="alert alert-danger fw-semibold mb-0" role="alert">Ordinary Employee</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
